#!/bin/bash
# Copy text to clipboard via OSC-52 (no streaming, no execution)
# Usage: copy_cmd echo "hello"     -> copies "echo hello"
#        echo "hello" | copy_cmd   -> copies "hello"

if [[ $# -gt 0 ]]; then
    cmd="$*"
else
    cmd=$(cat)
fi

printf '%s\n' "$cmd"

encoded=$(printf '%s' "$cmd" | base64 | tr -d '\n')

if [[ -n "$TMUX" ]]; then
    printf '\033Ptmux;\033\033]52;c;%s\033\033\\\033\\' "$encoded"
else
    printf '\033]52;c;%s\a' "$encoded"
fi
