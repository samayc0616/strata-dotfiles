autoload -U compinit && compinit -C  # Faster by avoiding unnecessary recompilation
compdef eza=ls
WORDCHARS='*?_-[]~=&;!#$%^(){}<>'

# Allow tab completion in the middle of a word
setopt COMPLETE_IN_WORD

# Background processes at full speed
setopt NO_BG_NICE

# Keep command history across sessions
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt INC_APPEND_HISTORY        # Immediately add to history
setopt SHARE_HISTORY             # Share between sessions
setopt HIST_IGNORE_DUPS          # Ignore duplicate entries
setopt HIST_IGNORE_SPACE         # Ignore commands prefixed with a space
setopt HIST_VERIFY               # Confirm before executing history expansion

# Disable annoying terminal bell
# setopt NO_BEEP

# Automatically decide when to page a list of completions
LISTMAX=0

# Disable mail checking
MAILCHECK=0

