# Redirect TMPDIR into the launch-dir so Claude's temp files don't hit the home quota.
# Per-PID subdir isolates concurrent sessions; EXIT trap cleans up on any exit.
claude() {
  # In $HOME, skip the .claude-tmp redirect so we don't pollute home — just use the default TMPDIR.
  if [[ "$PWD" == "$HOME" ]]; then
    command claude "$@"
    return
  fi
  # Sweep orphan subdirs from prior crashes (PID no longer alive)
  if [[ -d "$PWD/.claude-tmp" ]]; then
    for d in "$PWD/.claude-tmp"/*(N); do
      kill -0 "${d##*/}" 2>/dev/null || rm -rf "$d"
    done
  fi
  (
    local tmp="$PWD/.claude-tmp/$$"
    mkdir -p "$tmp"
    trap 'rm -rf "$tmp"' EXIT
    TMPDIR="$tmp" command claude "$@"
  )
  rmdir "$PWD/.claude-tmp" 2>/dev/null
}







# Enhanced Python-based notify function
# Usage: notify "command to run"
#    or: notify --silent "command to run"
#    or: notify --name "Custom Name" "command to run"
function notify() {
  ~/bin/notify "$@"
}

# Meta-N: Wrap current command with notify and execute
# Type your command with full tab completion, then hit Alt+N to run with notification
function __notify_and_run() {
  local cmd="$BUFFER"
  [[ -z "$cmd" ]] && return
  BUFFER="notify $cmd"
  zle accept-line
}
zle -N __notify_and_run
bindkey '˜' __notify_and_run  # Alt+N / Meta+N

# Alt+C: Copy current command line to clipboard (without executing)
function __copy_cmd_to_clipboard() {
  local cmd="$BUFFER"
  [[ -z "$cmd" ]] && return
  local encoded=$(printf '%s' "$cmd" | base64 | tr -d '\n')
  if [[ -n "$TMUX" ]]; then
    printf '\033Ptmux;\033\033]52;c;%s\033\033\\\033\\' "$encoded"
  else
    printf '\033]52;c;%s\a' "$encoded"
  fi
  zle -M "Copied: $cmd"
}
zle -N __copy_cmd_to_clipboard
bindkey 'ç' __copy_cmd_to_clipboard  # Alt+C


