# `nvim` launches (or re-attaches to) a single long-lived nvim instance inside
# a tmux session on a persistent Slurm compute node. The effect: slang-server
# and other LSPs stay alive between editing sessions, so large SV projects
# don't re-parse every time.
#
# Behavior:
#   - First call: allocates nvim-host on Slurm (8h, -c 4 --mem=8G), creates a
#     tmux session, launches nvim listening on a socket.
#   - Later calls: attach to the same nvim. Any file args are opened inside it
#     via `nvim --server $sock --remote`.
#   - If you :q'd last time (session survives via `exec zsh`), the next call
#     relaunches nvim in the same pane — seamless, but LSP is cold.
#
# Detach (keep LSP warm): `Ctrl-b d`
# Quit (drops LSP, session survives): `:q`
# Release node entirely: `scancel $(squeue -u $USER -n nvim-host -h -o %i)`
# Escape hatch to login-node nvim: `command nvim` or `\nvim`
_ensure_nvim_host() {
  local jid
  jid=$(squeue -u "$USER" -h -o "%i" -n nvim-host | head -1)
  if [[ -z "$jid" ]]; then
    echo "[nvim-host] starting persistent allocation (-c 4 --mem=8G, 8h)..." >&2
    salloc --no-shell -c 4 --mem=8G -J nvim-host --time=8:00:00 >/dev/null 2>&1
    jid=$(squeue -u "$USER" -h -o "%i" -n nvim-host | head -1)
  fi
  print -- "$jid"
}

nvim() {
  local jid sock=/tmp/nvim-$USER.sock
  jid=$(_ensure_nvim_host)
  if [[ -z "$jid" ]]; then
    echo "[nvim] Slurm alloc failed, falling back to login-node nvim" >&2
    command nvim "$@"
    return
  fi
  local args="${(j: :)@}"

  if srun --jobid="$jid" --quiet tmux has-session -t nvim 2>/dev/null; then
    if srun --jobid="$jid" --quiet nvim --server "$sock" --remote-expr 'v:true' >/dev/null 2>&1; then
      # nvim is warm — open files in it
      [[ $# -gt 0 ]] && srun --jobid="$jid" --quiet nvim --server "$sock" --remote "$@" 2>/dev/null
    else
      # session alive but nvim was :q'd — relaunch in the same pane
      srun --jobid="$jid" --quiet tmux send-keys -t nvim C-u "nvim --listen $sock $args" Enter
    fi
    srun --jobid="$jid" --pty tmux attach -t nvim
  else
    # first time: create session; :q falls through to zsh so session survives
    srun --jobid="$jid" --pty tmux new-session -s nvim "nvim --listen $sock $args; exec zsh"
  fi
}

